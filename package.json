{
  "name": "codeninja-dashboard",
  "version": "0.8.1",
  "description": "Code Ninjas Dashboard - Northridge Location",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/CodeNinjasDashboard.exe"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "*.html",
      "*.css",
      "*.js",
      "*.json",
      "Themes/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.15.0"
  }
}